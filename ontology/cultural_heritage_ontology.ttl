    crm:P7_took_place_at gres:place_TESTSPA0000003444 ;
    crm:P4_has_time-span gres:timespan_excavation_1994 ;
    crm:P14_carried_out_by gres:actor_denise_carruthers .

gres:dim_weight_demo_bone_1160
    a crm:E54_Dimension ;
